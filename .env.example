# Public (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL="https://<ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-key>"
NEXT_PUBLIC_DEMO_MODE="true" # demo builds only

# Server-only
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"
HARD_HAT_COMPANY_ID="<company-uuid>"

# Vapi (optional)
NEXT_PUBLIC_VAPI_PUBLIC_KEY="<vapi-public-key>"
NEXT_PUBLIC_VAPI_ASSISTANT_ID="<vapi-assistant-id>"

# Google Maps (optional)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="<maps-key>"


# Stripe API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
